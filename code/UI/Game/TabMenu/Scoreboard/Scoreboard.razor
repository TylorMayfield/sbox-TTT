@using System.Collections.Generic;
@using System;
@using Sandbox;
@using TTT.UI;

@namespace TTT.UI
@using Sandbox.UI;
@inherits Panel

<root>
    <ScoreboardInfo />
    <div class="background-color-primary rounded-bottom groups">
        @{
            var groups = new HashSet<PlayerStatus>();
            var players = PlayersByStatus();

            while (players.Count > 0)
            {
                var player = players.Dequeue();

                if (!groups.Contains(player.Status))
                {
                    groups.Add(player.Status);
                    <ScoreboardGroup Status=@player.Status />
                }

                <ScoreboardEntry Player=@player />
            }
        }
    </div>
</root>

@code {
    private PriorityQueue<TTT.Player, PlayerStatus> PlayersByStatus()
    {
        var players = new PriorityQueue<TTT.Player, PlayerStatus>();
        foreach (var player in Utils.GetPlayersWhere( _ => true ))
            players.Enqueue(player, player.Status);
        return players;
    }

    protected override int BuildHash()
    {
        return HashCode.Combine(Utils.GetPlayersWhere( _ => true ).HashCombine(p => HashCode.Combine(p.SteamId, (int)p.Status)));
    }
}

<style>
    Scoreboard {
        flex-direction: column;
        transition: bottom 0.2s ease-out;
        max-height: 70%;

        .groups {
            flex-direction: column;
            padding: 8 8 12 8;
            overflow: scroll;
        }

        &:intro {
            bottom: 25px;
        }
    }
</style>
