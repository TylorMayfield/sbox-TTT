@namespace TTT.UI
@using Sandbox.UI;
@inherits Panel

<root class="background-color-primary opacity-heavy text-shadow rounded">
    <span class="name">Voice</span>
</root>

@code {
    private string BorderColor() => PlayerStatus.Alive.GetColor().Hex;
}

<style>
    VoiceChatEntry {
        flex-direction: row;
        padding: 8px 8px;
        margin-bottom: 5px;
        align-items: center;
        transition: all 0.05s ease-out;
        border-bottom: 4px;
        border-color: @BorderColor();

        &:intro {
            opacity: 0;
            left: 10px;
        }

        &:outro {
            opacity: 0;
            left: 10px;
        }

        .avatar {
            width: 25px;
            height: 25px;
        }

        .name {
            font-weight: 700;
            font-size: 16px;
        }
    }
</style>
