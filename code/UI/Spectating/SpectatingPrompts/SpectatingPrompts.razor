@using Sandbox;
@using System;

@namespace TTT.UI
@using Sandbox.UI;
@inherits Panel

@if (TTT.Player.Local is not TTT.Player player || player.IsAlive)
{
	return;
}

<root>
	<div class="text-shadow" style="align-items: center; flex-direction: column;">
		@if (Spectating.Player.IsValid())
		{
			<div class="swap-panel">
				<span class="name"
				  style="color: @Hud.DisplayedPlayer?.Role?.Color.Hex">@Hud.DisplayedPlayer?.SteamName</span>
				<div style="align-items: center;">
					<span>Press</span>
					<InputGlyph action=@TTT.InputAction.PrimaryAttack />
					<span>or</span>
					<InputGlyph action=@TTT.InputAction.SecondaryAttack />
					<span>to swap active player</span>
				</div>
			</div>
		}

		@if (!player.Prop.IsValid() && !Spectating.Player.IsValid())
		{
			<div style="align-items: center;">
				<span>Press</span>
				<InputGlyph action=@TTT.InputAction.Use />
				<span>to spectate a player or possess a prop</span>
			</div>
		}

		<div style="align-items: center;">
			<span>Press</span>
			<InputGlyph action=@(player.Prop.IsValid() ? @TTT.InputAction.Duck : @TTT.InputAction.Jump) />
			<span>@(player.Prop.IsValid() ? "to no longer possess the prop" : "to change spectating camera mode")</span>
		</div>

		@if (player.LastAttacker?.Components.TryGet<TTT.Player>(out var attacker) == true && attacker != player)
		{
			<div class="report-panel background-color-primary rounded">
				<span class="report-title">Report Last Killer</span>
				<span>@attacker.SteamName (@attacker.Role.Title)</span>
				<Sandbox.UI.TextEntry Value=@ReportReason class="report-entry" />
				<button class="alt @(HasSubmittedReport ? "inactive" : "")" icon="report" @onclick=@SubmitRdmReport>
					@(HasSubmittedReport ? "Report Submitted" : "Submit RDM Report")
				</button>
			</div>
		}
	</div>
</root>

@code
{
	private string ReportReason { get; set; } = string.Empty;
	private bool HasSubmittedReport { get; set; }
	private int LastAttackerIdent { get; set; }

	public override void Tick()
	{
		var player = TTT.Player.Local;
		if ( player is null )
			return;

		var attackerIdent = player.LastAttacker?.Id.GetHashCode() ?? 0;
		if ( attackerIdent == LastAttackerIdent )
			return;

		LastAttackerIdent = attackerIdent;
		HasSubmittedReport = false;
		ReportReason = string.Empty;
	}

	public void SubmitRdmReport()
	{
		var player = TTT.Player.Local;
		if ( HasSubmittedReport || player is null )
			return;

		if ( player.LastAttacker?.Components.TryGet<TTT.Player>( out var attacker ) != true )
			return;

		TTT.GameManager.SubmitRdmReport( attacker.SteamId, ReportReason );
		HasSubmittedReport = true;
	}

	protected override int BuildHash()
	{
		var displayedPlayer = Hud.DisplayedPlayer;
		var localPlayer = TTT.Player.Local;
		return HashCode.Combine(displayedPlayer?.SteamId ?? 0, displayedPlayer?.IsAlive ?? false, displayedPlayer?.Prop?.Id.GetHashCode() ?? 0, localPlayer?.LastAttacker?.Id.GetHashCode() ?? 0, HasSubmittedReport, ReportReason);
	}
}

<style>
	SpectatingPrompts {
		position: absolute;
		left: 50%;
		bottom: 25px;
		transform: translateX(-50%);
		flex-direction: column;
		font-size: 17px;
		font-weight: 500;
		align-items: center;

		.name {
		font-size: 30px;
		font-weight: 600;
		}

	.swap-panel {
		align-items: center;
		flex-direction: column;
	}

	.report-panel {
		margin-top: 14px;
		padding: 10px;
		flex-direction: column;
		align-items: center;
		gap: 8px;
		min-width: 320px;
	}

	.report-title {
		font-weight: 700;
		font-size: 18px;
	}

	.report-entry {
		width: 100%;
	}

	}</style>

