@using Sandbox;
@using Sandbox.UI;
@using TTT.UI;

@namespace TTT.UI
@inherits RootPanel
@attribute [StyleSheet("/ui/Hud.scss")]

<root class="panel fullscreen">
    <HintDisplay />
    <PlayerInfo />
    <InventoryWrapper />
    <TextChat />
    <QuickChat />
    <VoiceChatDisplay />
    <RoundTimer />
    <InfoFeed />
    <FullScreenHintMenu />
    <TabMenu />
    <Crosshair />
    <CarriablePrompts />
    <SpectatingPrompts />
    <RoleMenu />
    <DamageIndicator />
    <WorldPoints />
</root>

@code
{
    public static Hud Instance { get; private set; }

    /// <summary>
    /// The player that we're currently displaying info about through UI elements.
    /// </summary>
    public static TTT.Player DisplayedPlayer => Spectating.Player.IsValid() ? Spectating.Player : TTT.Player.Local;

    public Hud()
    {
        Instance = this;
    }
}
